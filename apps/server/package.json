{
  "name": "@ward/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts",
    "build": "tsc",
    "db:check": "tsx src/db/check.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "user:admin": "tsx src/admin/users.ts",
    "user:create": "tsx src/admin/users.ts create",
    "user:delete": "tsx src/admin/users.ts delete",
    "user:list": "tsx src/admin/users.ts list",
    "user:reset-password": "tsx src/admin/users.ts reset-password",
    "user:set-dev-tools": "tsx src/admin/users.ts set-dev-tools",
    "user:set-email": "tsx src/admin/users.ts set-email",
    "user:set-role": "tsx src/admin/users.ts set-role",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "check": "tsc --noEmit --pretty false",
    "test:marketplace": "tsx --test src/marketplace/__tests__/marketplaceGuards.test.ts src/marketplace/__tests__/matching.test.ts"
  },
  "dependencies": {
    "@ward/engine": "workspace:*",
    "@ward/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "pg": "^8.20.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
