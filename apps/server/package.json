{
  "name": "@ward/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "db:check": "tsx src/db/check.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@ward/engine": "workspace:*",
    "@ward/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-session": "^1.19.0",
    "pg": "^8.20.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.19.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
