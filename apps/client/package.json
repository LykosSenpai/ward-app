{
  "name": "@ward/client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:embed-harness": "vite --open /embed-host-harness.html",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "check:dispatch-guards": "tsx scripts/boardPreview3dDispatchChecks.ts",
    "check:board-render-adapter": "tsx scripts/boardRenderAdapterChecks.ts",
    "check:board-preview-integration": "pnpm check && pnpm check:dispatch-guards && pnpm check:board-render-adapter && pnpm check:board-3d-gameplay-smoke && pnpm check:board-3d-battle-smoke && pnpm check:board-3d-multiplayer-smoke",
    "check:board-3d-gameplay-smoke": "tsx scripts/board3dGameplaySmoke.ts",
    "check:phase4-qa": "node scripts/phase4QaSuite.mjs",
    "check:board-3d-battle-smoke": "tsx scripts/board3dBattlePromptSmoke.ts",
    "check:board-3d-multiplayer-smoke": "tsx scripts/board3dMultiplayerMatrixSmoke.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "@ward/shared": "workspace:*",
    "react": "latest",
    "react-dom": "latest",
    "socket.io-client": "^4.7.0",
    "three": "^0.184.0",
    "typescript": "^5.0.0",
    "vite": "latest",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
