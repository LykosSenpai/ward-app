SKIP_LOCAL_EMAIL_LOGIN_CODE=false
VITE_API_BASE_URL=http://localhost:3001
VITE_SKIP_LOCAL_EMAIL_VERIFICATION=true
VITE_ENABLE_DEV_TOOLS=false

