{
  "name": "ward-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @ward/client dev",
    "dev:server": "pnpm --filter @ward/server dev",
    "db:check": "pnpm --filter @ward/server db:check",
    "db:migrate": "pnpm --filter @ward/server db:migrate",
    "user:admin": "pnpm --filter @ward/server user:admin",
    "user:create": "pnpm --filter @ward/server user:create",
    "user:delete": "pnpm --filter @ward/server user:delete",
    "user:list": "pnpm --filter @ward/server user:list",
    "user:reset-password": "pnpm --filter @ward/server user:reset-password",
    "user:set-dev-tools": "pnpm --filter @ward/server user:set-dev-tools",
    "user:set-email": "pnpm --filter @ward/server user:set-email",
    "user:set-role": "pnpm --filter @ward/server user:set-role",
    "build": "pnpm -r build",
    "vercel:client:build": "pnpm --filter @ward/shared build && pnpm --filter @ward/client build",
    "railway:build": "pnpm --filter @ward/shared build && pnpm --filter @ward/engine build && pnpm --filter @ward/client build && pnpm --filter @ward/server build",
    "start": "pnpm --filter @ward/server start",
    "cards:build": "node tools/card-generation/build-card-packs.mjs",
    "cards:check": "node tools/card-generation/build-card-packs.mjs --check",
    "check": "node tools/workspace-check.mjs",
    "check:css": "node tools/check-css-braces.mjs",
    "check:exports": "node tools/check-engine-exports.mjs",
    "check:files": "node tools/check-project-files.mjs",
    "check:types": "pnpm --filter @ward/shared check && pnpm --filter @ward/engine check && pnpm --filter @ward/server check && pnpm --filter @ward/client check",
    "effects:audit": "node tools/card-generation/audit-effect-runtime-coverage.mjs",
    "qa:effects": "pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-headless-effect-qa.ts",
    "qa:gen1:deck-sweep": "pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-gen1-full-deck-engine-sweep.ts",
    "qa:gen1:setup-users": "pnpm --filter @ward/server exec tsx --conditions=development ../../tools/setup-gen1-qa-users.ts",
    "qa:gen1:lobby-smoke": "pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts",
    "qa:gen1:lobby-sweep": "pnpm qa:gen1:lobby-smoke",
    "qa:gen2:deck-sweep": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='2'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-gen1-full-deck-engine-sweep.ts\"",
    "qa:gen2:setup-users": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='2'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/setup-gen1-qa-users.ts\"",
    "qa:gen2:lobby-smoke": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='2'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "qa:gen2:lobby-sweep": "pnpm qa:gen2:lobby-smoke",
    "qa:gen3:deck-sweep": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='3'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-gen1-full-deck-engine-sweep.ts\"",
    "qa:gen3:setup-users": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='3'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/setup-gen1-qa-users.ts\"",
    "qa:gen3:lobby-smoke": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='3'; $env:WARD_QA_EXPECTED_CARD_COUNT='151'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "qa:gen3:lobby-sweep": "pnpm qa:gen3:lobby-smoke",
    "qa:gen3:lobby-cleanup": "powershell -NoProfile -Command \"$env:WARD_QA_GENERATION='3'; $env:WARD_QA_CLEANUP_ONLY='1'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "qa:gen1-gen2:deck-sweep": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2'; $env:WARD_QA_LABEL='Gen1+Gen2'; $env:WARD_QA_SLUG='gen1_gen2'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-gen1-full-deck-engine-sweep.ts\"",
    "qa:gen1-gen2:setup-users": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2'; $env:WARD_QA_LABEL='Gen1+Gen2'; $env:WARD_QA_SLUG='gen1_gen2'; $env:WARD_QA_DECK_COUNT='16'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/setup-gen1-qa-users.ts\"",
    "qa:gen1-gen2:lobby-smoke": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2'; $env:WARD_QA_LABEL='Gen1+Gen2'; $env:WARD_QA_SLUG='gen1_gen2'; $env:WARD_QA_DECK_COUNT='16'; $env:WARD_QA_EXPECTED_CARD_COUNT='301'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "qa:gen1-gen2:lobby-sweep": "pnpm qa:gen1-gen2:lobby-smoke",
    "qa:all-gens:deck-sweep": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2,ward-gen3'; $env:WARD_QA_LABEL='Gen1+Gen2+Gen3'; $env:WARD_QA_SLUG='gen1_gen2_gen3'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/run-gen1-full-deck-engine-sweep.ts\"",
    "qa:all-gens:setup-users": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2,ward-gen3'; $env:WARD_QA_LABEL='Gen1+Gen2+Gen3'; $env:WARD_QA_SLUG='gen1_gen2_gen3'; $env:WARD_QA_DECK_COUNT='26'; pnpm --filter @ward/server exec tsx --conditions=development ../../tools/setup-gen1-qa-users.ts\"",
    "qa:all-gens:lobby-smoke": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2,ward-gen3'; $env:WARD_QA_LABEL='Gen1+Gen2+Gen3'; $env:WARD_QA_SLUG='gen1_gen2_gen3'; $env:WARD_QA_DECK_COUNT='26'; $env:WARD_QA_EXPECTED_CARD_COUNT='453'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "qa:all-gens:lobby-sweep": "pnpm qa:all-gens:lobby-smoke",
    "qa:all-gens:lobby-cleanup": "powershell -NoProfile -Command \"$env:WARD_QA_PACK_IDS='ward-gen1,ward-gen2,ward-gen3'; $env:WARD_QA_LABEL='Gen1+Gen2+Gen3'; $env:WARD_QA_SLUG='gen1_gen2_gen3'; $env:WARD_QA_DECK_COUNT='26'; $env:WARD_QA_CLEANUP_ONLY='1'; pnpm --filter @ward/client exec tsx ../../tools/run-gen1-lobby-smoke.ts\"",
    "test:marketplace": "pnpm --filter @ward/server run test:marketplace",
    "images:import:excel": "node tools/card-images/import-excel-image-links.mjs",
    "images:validate": "node tools/card-images/validate-image-candidates.mjs",
    "images:smoke:phase4": "node tools/card-images/phase4-smoke-check.mjs",
    "images:delta": "node tools/card-images/check-validation-delta.mjs"
  },
  "devDependencies": {
    "fast-glob": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "xlsx": "^0.18.5"
  }
}
